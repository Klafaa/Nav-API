{
  "name": "nav-online-szamla-api",
  "version": "1.0.0",
  "module": "src/index.ts",
  "type": "module",
  "private": true,
  "description": "Type-safe NAV Online Számla 3.0 API gateway: Bun + Elysia + Drizzle + GraphQL",
  "scripts": {
    "dev": "bun --watch src/index.ts",
    "start": "bun src/index.ts",
    "build": "bun build src/index.ts --target bun --outdir dist",
    "typecheck": "tsc --noEmit",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "bun src/db/migrate.ts",
    "db:studio": "drizzle-kit studio",
    "test": "bun test"
  },
  "devDependencies": {
    "@types/bun": "^1.3.13",
    "drizzle-kit": "^0.31.10",
    "typescript": "^5.7.2"
  },
  "dependencies": {
    "@pothos/core": "^4.12.0",
    "drizzle-orm": "^0.45.2",
    "elysia": "^1.4.28",
    "fast-xml-parser": "^4.5.3",
    "graphql": "^16.11.0",
    "graphql-scalars": "^1.24.2",
    "graphql-yoga": "^5.16.1",
    "zod": "^3.24.1"
  }
}
