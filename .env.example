# --- Server ---
PORT=4000
NODE_ENV=development

# --- Database (Bun SQLite) ---
DATABASE_URL=./data/nav.sqlite

# --- NAV Online Számla 3.0 environment ---
# Production: https://api.onlineszamla.nav.gov.hu/invoiceService/v3
# Test:       https://api-test.onlineszamla.nav.gov.hu/invoiceService/v3
NAV_BASE_URL=https://api-test.onlineszamla.nav.gov.hu/invoiceService/v3

# --- Default technical user (optional, can also be supplied per-request via GraphQL) ---
NAV_LOGIN=
NAV_PASSWORD=
NAV_SIGN_KEY=
NAV_EXCHANGE_KEY=
NAV_TAX_NUMBER=

# --- Software registration (mandatory header for every call, see NAV spec §1.5) ---
NAV_SOFTWARE_ID=                     # exactly 18 chars (HU + tax number + dash + 8 chars)
NAV_SOFTWARE_NAME=NAV-Online-Szamla-Gateway
NAV_SOFTWARE_OPERATION=ONLINE_SERVICE  # ONLINE_SERVICE | LOCAL_SOFTWARE
NAV_SOFTWARE_MAIN_VERSION=1.0.0
NAV_SOFTWARE_DEV_NAME=Your Company Kft.
NAV_SOFTWARE_DEV_CONTACT=dev@example.com
NAV_SOFTWARE_DEV_COUNTRY_CODE=HU
NAV_SOFTWARE_DEV_TAX_NUMBER=
